    "test.deleteStatsDetail" : { "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "About to delete:\n• %d attack records\n• %d medications\n• %d custom labels\n• %d health events\n• %d user profiles\n• %d medication logs\n\nCannot be undone!" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "即将删除：\n• %d 条发作记录\n• %d 种药物\n• %d 个自定义标签\n• %d 个健康事件\n• %d 个用户档案\n• %d 条用药日志\n\n此操作不可恢复！" } }, "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "即將刪除：\n• %d 條發作記錄\n• %d 種藥物\n• %d 個自訂標籤\n• %d 個健康事件\n• %d 個用戶檔案\n• %d 條用藥日誌\n\n此操作不可恢復！" } } } },
